{
  "name": "obsidian-artifacts-leetcode-vscode",
  "displayName": "Obsidian Artifacts: AI LeetCode Trainer",
  "description": "Turn type: leetcode notes in your Obsidian vault into runnable coding challenges with auto-generated boilerplate, a per-language test harness, and a child-process test runner.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.117.0"
  },
  "categories": [
    "Education",
    "Testing",
    "Other"
  ],
  "keywords": [
    "leetcode",
    "obsidian",
    "coding practice",
    "interview prep",
    "algorithms"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "obsidian-leetcode.settings",
        "category": "Obsidian Artifacts",
        "title": "Settings"
      },
      {
        "command": "obsidian-leetcode.create",
        "category": "Obsidian Artifacts",
        "title": "Create LeetCode Exercise"
      },
      {
        "command": "obsidian-leetcode.open",
        "category": "Obsidian Artifacts",
        "title": "Open LeetCode Exercise"
      }
    ],
    "submenus": [
      {
        "id": "obsidian-leetcode.contextMenu",
        "label": "Obsidian Artifacts"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "obsidian-leetcode.contextMenu",
          "group": "obsidian@1"
        }
      ],
      "obsidian-leetcode.contextMenu": [
        {
          "command": "obsidian-leetcode.settings",
          "group": "obsidian@1"
        },
        {
          "command": "obsidian-leetcode.create",
          "group": "obsidian@2"
        },
        {
          "command": "obsidian-leetcode.open",
          "when": "obsidian-leetcode.vaultConfigured",
          "group": "obsidian@3"
        }
      ],
      "commandPalette": [
        {
          "command": "obsidian-leetcode.open",
          "when": "obsidian-leetcode.vaultConfigured"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "25.6.0",
    "@types/vscode": "^1.116.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  }
}
